{
    # Correo para el registro automático de Let's Encrypt (ACME)
    email {$ACME_EMAIL:tuemail@ejemplo.com}
}

# Usa el dominio configurado en .env, si no hay, usa el puerto 80 por defecto
hookahub.me {
    # WebSockets para el chat (Socket.IO)
    handle /socket.io/* {
        reverse_proxy backend:3000
    }

    # Archivos estáticos subidos por usuarios (avatares, imágenes de productos)
    # NestJS los sirve en /uploads — se exponen directamente sin quitar el prefijo
    handle /uploads/* {
        reverse_proxy backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Redirigir el API al contenedor del backend (NestJS)
    handle_path /api/* {
        reverse_proxy backend:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Redirigir todo lo demás al contenedor del frontend (Nginx/React)
    handle {
        reverse_proxy frontend:80
    }
}
